{
  "autoExecution": "always-proceed",
  "reviewPolicy": "agent-decides",
  "planningPolicy": "auto",
  "safeToAutoRun": true,
  "permissions": {
    "alwaysAllow": [
      "read_file",
      "list_directory",
      "search_files",
      "view_file",
      "grep_search",
      "git status",
      "git diff",
      "git log",
      "git branch",
      "git stash list",
      "git remote -v",
      "git show",
      "npm run dev",
      "npm run build",
      "npm test",
      "npm list",
      "npm outdated",
      "npm run lint",
      "python --version",
      "pip list",
      "pip show",
      "node --version",
      "npm --version",
      "cat",
      "echo",
      "type",
      "dir",
      "Get-ChildItem",
      "Get-Content",
      "Select-String",
      "Test-Path",
      "Get-Item",
      "Get-Date",
      "pwd",
      "whoami",
      "hostname",
      "tree",
      "wc",
      "head",
      "tail",
      "find",
      "where",
      "which"
    ],
    "alwaysDeny": [
      "rm -rf /",
      "rm -rf /*",
      "rm -rf ~",
      "rm -rf .",
      "del /s /q C:\\",
      "rd /s /q C:\\",
      "rd /s /q .",
      "Remove-Item -Recurse -Force C:\\",
      "Remove-Item -Recurse -Force /",
      "format",
      "shutdown",
      "restart",
      "Restart-Computer",
      "Stop-Computer",
      "Clear-Disk",
      "DROP DATABASE",
      "DROP SCHEMA",
      "DROP TABLE",
      "DROP TABLESPACE",
      "TRUNCATE TABLE",
      "DELETE FROM",
      "DROP USER",
      "ALTER SYSTEM",
      "PURGE RECYCLEBIN",
      "git push --force",
      "git reset --hard",
      "git clean -fdx",
      "git branch -D main",
      "git branch -D master",
      "npm unpublish",
      "Set-ExecutionPolicy Unrestricted",
      "Invoke-WebRequest",
      "curl | bash",
      "iex",
      "New-Service",
      "Stop-Service",
      "net stop",
      "taskkill /f",
      "reg delete",
      "regedit"
    ],
    "alwaysAsk": [
      "git push",
      "git commit",
      "git merge",
      "git rebase",
      "git checkout main",
      "git checkout master",
      "git reset",
      "git stash drop",
      "git tag",
      "npm install",
      "npm publish",
      "npm uninstall",
      "npx",
      "pip install",
      "pip uninstall",
      "python -m pip install",
      "deploy",
      "docker rm",
      "docker rmi",
      "docker stop",
      "docker-compose down",
      "New-Item",
      "Move-Item",
      "Rename-Item",
      "Copy-Item",
      "Set-Content",
      "Out-File",
      "sqlplus",
      "sqlcmd"
    ]
  }
}
