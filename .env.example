# AgentSpec /validate skill — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and NEVER committed to version control.

# LLM Provider API Key (OpenRouter, OpenAI, etc.)
OPENAI_API_KEY=your-key-here

# Optional: Override base URL for OpenRouter or other providers
# Leave commented to use OpenAI directly
OPENAI_API_BASE=https://openrouter.ai/api/v1

# Optional: Override model name (default: gpt-4o-mini)
# CREWAI_MODEL=openai/gpt-5.5
